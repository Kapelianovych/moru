{
  "type": "module",
  "workspaces": [
    "./ui",
    "./core",
    "./store",
    "./server",
    "./website",
    "./controller",
    "./vite-plugin"
  ],
  "scripts": {
    "format": "prettier . --write",
    "test:core": "node --test \"./core/tests/**/*.test.js\"",
    "test:store": "node --test \"./store/tests/**/*.test.js\"",
    "test:controller": "vitest run --config ./vitest.config.controller.js",
    "start:website": "npm start -w website",
    "build:website": "npm run build -w website"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@vitest/browser-playwright": "4.1.2",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
